# =====================================================================
# TEXKI2 — modelo de variáveis de ambiente
# Copie para `.env` (NÃO versionado) e troque todos os "change-me".
# =====================================================================

# Domínio público do serviço (sem protocolo).
# Local: adicione em /etc/hosts → "127.0.0.1 texki2.local"
# Produção: o domínio real, ex.: texki2.livreprint.com
DOMAIN=texki2.local

# Diretiva TLS do Caddy.
#   "internal" → Caddy usa CA própria (dev local, HTTPS com cert autoassinado)
#   "seu@email.com" → Let's Encrypt (produção, exige DNS público apontando p/ VPS)
ACME_EMAIL_OR_INTERNAL=internal

# Postgres
POSTGRES_USER=texki
POSTGRES_PASSWORD=change-me
POSTGRES_DB=texki2

# URL usada pela API (referencia o serviço `db` da rede do compose).
# Mantenha usuário/senha/banco coerentes com as 3 variáveis acima.
DATABASE_URL=postgresql+psycopg://texki:change-me@db:5432/texki2

# JWT (cookie httpOnly de sessão)
JWT_SECRET=change-me-troque-por-um-segredo-aleatorio-bem-longo
JWT_EXPIRES_MINUTES=60

# Seed do primeiro administrador (idempotente).
# Rodado uma vez via `docker compose exec api python -m app.db.seed`.
SEED_ADMIN_EMAIL=admin@livreprint.com
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_NOME=Administrador
